# =============================================================================
# PokeDrafter — Root .gitignore
# Covers: Angular (web/), Python FastAPI (api/), Docker/K8s (infra/), OS, IDEs
# =============================================================================

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDEs & Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Angular / Node.js  (web/)
# -----------------------------------------------------------------------------
node_modules/
dist/
.angular/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
coverage/
.nyc_output/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Python  (api/*)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python
build/
develop-eggs/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.env/
Pipfile.lock
poetry.lock

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover

# Type checkers & linters
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# Alembic — keep migration scripts, ignore compiled bytecode only
# (versions/*.py are tracked)

# -----------------------------------------------------------------------------
# Environment & Secrets  (NEVER commit real secrets)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
infra/docker/.env
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# Kubernetes secrets manifest (contains base64-encoded credentials)
infra/k8s/config/secrets.yaml

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Keep docker-compose files; ignore overrides with real credentials
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Logs & runtime
# -----------------------------------------------------------------------------
*.log
logs/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Misc build artifacts
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
*.orig

